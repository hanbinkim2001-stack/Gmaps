# 네이버 클라우드 플랫폼 > Maps > Dynamic Map Client ID (지도 JS)
VITE_NAVER_MAP_CLIENT_ID=

# 네이버 개발자센터(검색 API) — 지역 검색용. VITE_ 접두사 없음 → 브라우저에 노출되지 않고 Vite 개발 서버 프록시에서만 사용
# https://developers.naver.com/apps — 앱에서「검색」API 사용 설정
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# (배포 시 Netlify 환경변수에도 VITE_NAVER_MAP_CLIENT_ID를 꼭 넣어야 지도 스크립트가 로드됩니다.)
# 아래 2개는 주소 검색(지오코딩)용 NCP API Gateway 키로, 배포 시 Netlify 환경변수에 넣으세요.
NAVER_MAPS_API_KEY_ID=
NAVER_MAPS_API_KEY=
